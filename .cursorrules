# ==========================
# ENVIRONNEMENT VIRTUEL
# ==========================

env:
  python: "venv\\Scripts\\python.exe"
  pip: "venv\\Scripts\\pip.exe"

# 🚨 RÈGLE CRITIQUE : TOUJOURS UTILISER L'ENVIRONNEMENT VIRTUEL venv
# Toutes les commandes Python et pip DOIVENT utiliser les chemins ci-dessus

# ==========================
# COMMANDES
# ==========================

commands:
  run: "venv\\Scripts\\python.exe main.py"
  install: "venv\\Scripts\\pip.exe install"
  update: "venv\\Scripts\\pip.exe install --upgrade"
  list: "venv\\Scripts\\pip.exe list"

# ==========================
# VÉRIFICATION ENVIRONNEMENT
# ==========================

check:
  - "venv\\Scripts\\python.exe --version"
  - "venv\\Scripts\\pip.exe list"
  - "venv\\Scripts\\python.exe -c \"import sys; print(sys.executable)\""

# ==========================
# STARTUP SERVICES
# ==========================

startup:
  backend: |
    cd backend
    venv\\Scripts\\python.exe main.py
  frontend: |
    taskkill /F /IM node.exe /T
    cd frontend
    npm run dev

# ==========================
# PORTS UTILISÉS
# ==========================

ports:
  backend: 8000
  frontend: 3000
  docs: "http://localhost:8000/docs"

# ==========================
# BONNES PRATIQUES
# ==========================

# ✅ UTILISATION DES OUTILS
# - cd backend && venv\Scripts\pip.exe install nom_du_package
# - cd backend && venv\Scripts\python.exe main.py
# ❌ Ne JAMAIS utiliser `pip` ou `python` sans venv !

# RAISONS :
# - Isolation des dépendances
# - Cohérence entre devs
# - Fiabilité du projet
# - Reproductibilité en prod

# ==========================
# RÈGLES DE DÉVELOPPEMENT
# ==========================

rules:
  # Développement
  - "Adapter le code existant plutôt que de créer du nouveau"
  - "Modifier les composants existants au lieu d'en créer de nouveaux"
  - "Supprimer et refaire si nécessaire, mais pas de doublons"
  - "Vérifier la structure existante avant toute modification"
  - "Quand une requête complexe est envoyée, Cursor doit automatiquement :
     - comprendre les sous-tâches,
     - dispatcher les tâches vers les agents les plus compétents,
     - les exécuter en parallèle si possible,
     - fusionner les résultats pour répondre sans demander d'effort supplémentaire à l'utilisateur"
  
  # Conception
  - "TOUJOURS utiliser l'environnement virtuel venv"
  - "Ajouter une règle dans cursorrules à chaque modification"
  - "NE JAMAIS créer de code doublon ou redondant"
  - "Si du code existe déjà, l'utiliser et l'améliorer"
  - "Supprimer le code obsolète au lieu de le laisser en place"
